CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
ADMIN_USER=admin
ADMIN_PASSWORD=change_me
JWT_SECRET=super_secret_key
ENVIRONMENT=local
# Las rutas por defecto usan storage/uploads y storage/parquet en la misma carpeta del backend, 
# pero pueden ser configuradas aquí para apuntar a otras carpetas (ej. disco persistente en Render).
# UPLOADS_DIR=/opt/render/project/src/backend/storage/uploads
# PARQUET_DIR=/opt/render/project/src/backend/storage/parquet
